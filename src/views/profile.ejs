<div class="container my-5">

  <!-- User Info Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
      
      <div>
        <h4 class="mb-1" id="userName">Huzaifa Ali</h4>
        <p class="mb-0 text-muted" id="accountNumber">Account Number: 123456789012</p>
      </div>

      <div class="text-end mt-3 mt-md-0">
        <h5 class="text-muted mb-1">Available Balance</h5>
        <h3 class="text-success" id="accountBalance">0</h3>
      </div>

    </div>
  </div>

  <!-- Action Button -->
  <div class="d-flex justify-content-end mb-4">
    <a href="/transaction" class="btn btn-primary px-4">
      + New Transaction
    </a>
  </div>

  <!-- Transaction History -->
  <div class="card shadow-sm">
    <div class="card-header bg-white">
      <h5 class="mb-0">Transaction History</h5>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Status</th>
            <th class="text-end">Amount</th>
          </tr>
        </thead>

        <tbody id="transaction-history">
          <!-- Transaction Row -->
        </tbody>
      </table>
    </div>
  </div>

</div>