<div class="container my-5">

  <!-- User Info Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
      
      <div>
        <h4 class="mb-1">Huzaifa Ali</h4>
        <p class="mb-0 text-muted">Account Number: 123456789012</p>
      </div>

      <div class="text-end mt-3 mt-md-0">
        <h5 class="text-muted mb-1">Available Balance</h5>
        <h3 class="text-success" id="accountBalance">0</h3>
      </div>

    </div>
  </div>

  <!-- Action Button -->
  <div class="d-flex justify-content-end mb-4">
    <a href="/transaction" class="btn btn-primary px-4">
      + New Transaction
    </a>
  </div>

  <!-- Transaction History -->
  <div class="card shadow-sm">
    <div class="card-header bg-white">
      <h5 class="mb-0">Transaction History</h5>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Description</th>
            <th class="text-end">Amount</th>
            <th class="text-end">Balance</th>
          </tr>
        </thead>

        <tbody>

          <!-- Transaction Row -->
          <tr>
            <td>2026-04-03</td>
            <td><span class="badge bg-success">Credit</span></td>
            <td>Salary Deposit</td>
            <td class="text-end text-success">+ Rs. 100,000</td>
            <td class="text-end">Rs. 250,000</td>
          </tr>

          <tr>
            <td>2026-04-02</td>
            <td><span class="badge bg-danger">Debit</span></td>
            <td>Online Shopping</td>
            <td class="text-end text-danger">- Rs. 5,000</td>
            <td class="text-end">Rs. 150,000</td>
          </tr>

          <tr>
            <td>2026-04-01</td>
            <td><span class="badge bg-success">Credit</span></td>
            <td>Freelance Payment</td>
            <td class="text-end text-success">+ Rs. 50,000</td>
            <td class="text-end">Rs. 155,000</td>
          </tr>

        </tbody>
      </table>
    </div>
  </div>

</div>