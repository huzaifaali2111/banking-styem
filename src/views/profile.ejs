<div class="container my-5">

  <!-- Top Bar (Profile Section Added) -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Dashboard</h4>

    <!-- Profile Dropdown -->
    <div class="dropdown">
      <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
        Profile
      </button>
      <ul class="dropdown-menu dropdown-menu-end shadow">
        <li>
          <a class="dropdown-item" href="/forgot-password">
            Forgot Password
          </a>
        </li>
        <li><hr class="dropdown-divider"></li>
        <li>
          <button class="dropdown-item text-danger" id="logoutBtn">
            Logout
          </button>
        </li>
      </ul>
    </div>
  </div>


  <!-- User Info Card -->
  <div class="card shadow-sm mb-4">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap">
      
      <div>
        <h4 class="mb-1 fw-bold" id="userName"></h4>
        <p class="mb-0 text-muted" id="accountNumber"></p>
      </div>

      <div class="text-end mt-3 mt-md-0">
        <h6 class="text-muted mb-1">Available Balance</h6>
        <h2 class="text-success fw-bold" id="accountBalance">0</h2>
      </div>

    </div>
  </div>

  <!-- Action Button -->
  <div class="d-flex justify-content-end mb-4">
    <a href="/transaction" class="btn btn-primary px-4 shadow-sm">
      + New Transaction
    </a>
  </div>

  <!-- Transaction History -->
  <div class="card shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
      <h5 class="mb-0">Transaction History</h5>
    </div>

    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Status</th>
            <th class="text-end">Amount</th>
          </tr>
        </thead>

        <tbody id="transaction-history">
          <!-- Transaction Row -->
        </tbody>
      </table>
    </div>
  </div>

</div>